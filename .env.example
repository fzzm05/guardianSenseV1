# Server-only database connection used by Drizzle, pg, and migrations
DATABASE_URL=

# Redis connection details for server-side caching and session management
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used by the internal location job worker endpoint
LOCATION_EVENTS_WORKER_SECRET=

# Redis geofence cache TTL in seconds
GEOFENCE_CACHE_TTL_SECONDS=

# Shared Supabase project values used by the web app and future mobile app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Firebase client config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin config
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
