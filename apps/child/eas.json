{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://guardian-sense-v1-web.vercel.app"
      }
    },
    "production": {
      "android": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://guardian-sense-v1-web.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
